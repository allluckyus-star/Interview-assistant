<Window x:Class="InterviewAssistant.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:InterviewAssistant.App"
        xmlns:ui="clr-namespace:InterviewAssistant.App.Ui"
        Title="Interview Assistant"
        Width="900"
        Height="680"
        MinWidth="520"
        MinHeight="320"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        SnapsToDevicePixels="True"
        FontFamily="{StaticResource AppFontFamily}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Loaded="MainWindow_OnLoaded">
  <shell:WindowChrome.WindowChrome>
    <WindowChrome CaptionHeight="0"
                  ResizeBorderThickness="10"
                  GlassFrameThickness="0"
                  CornerRadius="0"
                  UseAeroCaptionButtons="False" />
  </shell:WindowChrome.WindowChrome>

  <Border x:Name="ShellCard"
          Margin="8"
          Background="#FCFCFF"
          BorderBrush="#E2E8F0"
          BorderThickness="1"
          CornerRadius="12"
          Padding="14">
    <Grid>
      <DockPanel LastChildFill="True">
      <!-- Top bar -->
      <Grid DockPanel.Dock="Top" Height="36">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   VerticalAlignment="Center"
                   FontSize="12"
                   FontWeight="Bold"
                   Foreground="#222222"
                   Text="Interview Assistant"
                   Cursor="Hand"
                   MouseLeftButtonDown="DragRegion_OnMouseLeftButtonDown" />

        <Grid Grid.Column="1"
              VerticalAlignment="Stretch">
          <Border Background="Transparent"
                  Cursor="Hand"
                  MouseLeftButtonDown="DragRegion_OnMouseLeftButtonDown" />
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <TextBlock Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       FontSize="11"
                       FontWeight="Bold"
                       Foreground="#222222"
                       Text="Opacity"
                       ToolTip="Whole-window opacity (0 = transparent)." />
            <Slider x:Name="OpacitySlider"
                    Width="200"
                    VerticalAlignment="Center"
                    Maximum="100"
                    Minimum="0"
                    SmallChange="1"
                    LargeChange="10"
                    IsSnapToTickEnabled="False"
                    ToolTip="Drag to fade the window. Alt+Shift+1 = recent opacity, Alt+Shift+2 = hide (0%)."
                    Value="80"
                    ValueChanged="OpacitySlider_OnValueChanged" />
          </StackPanel>
        </Grid>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
          <StackPanel x:Name="InterviewTopBarPanel"
                      Orientation="Horizontal"
                      Margin="0,0,6,0"
                      Visibility="Collapsed">
            <Border x:Name="SessionModeSegmentHost"
                    Height="32"
                    Margin="0,0,6,0"
                    Padding="3,2"
                    Background="#b2ebf2"
                    CornerRadius="16">
              <Border.Effect>
                <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.22" Color="#000000" />
              </Border.Effect>
              <StackPanel Orientation="Horizontal"
                          VerticalAlignment="Center">
                <Button x:Name="SessionModeReadButton"
                        Style="{StaticResource TopBarSessionSegmentButtonStyle}"
                        Tag="read"
                        Click="SessionModeSegment_OnClick"
                        ToolTip="Read mode"
                        Width="28"
                        Height="28"
                        MinWidth="28">
                  <StackPanel Orientation="Horizontal"
                              HorizontalAlignment="Center">
                    <Viewbox x:Name="SessionModeReadIconHost"
                             Width="14"
                             Height="14"
                             VerticalAlignment="Center"
                             RenderTransformOrigin="0.5,0.5">
                      <Viewbox.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                      </Viewbox.RenderTransform>
                    </Viewbox>
                    <Border x:Name="SessionModeReadTextClip"
                            VerticalAlignment="Center"
                            Margin="5,0,2,0"
                            ClipToBounds="True"
                            MaxWidth="0">
                      <TextBlock x:Name="SessionModeReadLabel"
                                 FontSize="11"
                                 FontWeight="Bold"
                                 Foreground="#222222"
                                 TextTrimming="CharacterEllipsis"
                                 TextWrapping="NoWrap"
                                 Text="Read" />
                    </Border>
                  </StackPanel>
                </Button>
                <Button x:Name="SessionModeTypeButton"
                        Style="{StaticResource TopBarSessionSegmentButtonStyle}"
                        Tag="type"
                        Click="SessionModeSegment_OnClick"
                        ToolTip="Type mode"
                        Width="28"
                        Height="28"
                        MinWidth="28">
                  <StackPanel Orientation="Horizontal"
                              HorizontalAlignment="Center">
                    <Viewbox x:Name="SessionModeTypeIconHost"
                             Width="14"
                             Height="14"
                             VerticalAlignment="Center"
                             RenderTransformOrigin="0.5,0.5">
                      <Viewbox.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                      </Viewbox.RenderTransform>
                    </Viewbox>
                    <Border x:Name="SessionModeTypeTextClip"
                            VerticalAlignment="Center"
                            Margin="5,0,2,0"
                            ClipToBounds="True"
                            MaxWidth="0">
                      <TextBlock x:Name="SessionModeTypeLabel"
                                 FontSize="11"
                                 FontWeight="Bold"
                                 Foreground="#222222"
                                 TextTrimming="CharacterEllipsis"
                                 TextWrapping="NoWrap"
                                 Text="Type" />
                    </Border>
                  </StackPanel>
                </Button>
                <Button x:Name="SessionModeBehavioralButton"
                        Style="{StaticResource TopBarSessionSegmentButtonStyle}"
                        Tag="behavioral"
                        Click="SessionModeSegment_OnClick"
                        ToolTip="Behavioral mode"
                        Width="28"
                        Height="28"
                        MinWidth="28">
                  <StackPanel Orientation="Horizontal"
                              HorizontalAlignment="Center">
                    <Viewbox x:Name="SessionModeBehavioralIconHost"
                             Width="14"
                             Height="14"
                             VerticalAlignment="Center"
                             RenderTransformOrigin="0.5,0.5">
                      <Viewbox.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                      </Viewbox.RenderTransform>
                    </Viewbox>
                    <Border x:Name="SessionModeBehavioralTextClip"
                            VerticalAlignment="Center"
                            Margin="5,0,2,0"
                            ClipToBounds="True"
                            MaxWidth="0">
                      <TextBlock x:Name="SessionModeBehavioralLabel"
                                 FontSize="11"
                                 FontWeight="Bold"
                                 Foreground="#222222"
                                 TextTrimming="CharacterEllipsis"
                                 TextWrapping="NoWrap"
                                 Text="Behavioral" />
                    </Border>
                  </StackPanel>
                </Button>
              </StackPanel>
            </Border>
            <ToggleButton x:Name="StealthToggleButton"
                          Style="{StaticResource TopBarCyanCircleToggleStyle}"
                          Margin="0,0,6,0"
                          Click="StealthToggleButton_OnClick"
                          ToolTip="Stealth: hidden from screen capture">
              <Viewbox x:Name="StealthIconHost" Width="16" Height="16" />
            </ToggleButton>
            <Button x:Name="SaveTranscriptButton"
                    Style="{StaticResource TopBarCyanCircleButtonStyle}"
                    Margin="0,0,6,0"
                    ToolTip="Save interview transcript"
                    Click="SaveTranscriptButton_OnClick">
              <Viewbox x:Name="SaveTranscriptIconHost" Width="16" Height="16" />
            </Button>
            <Button x:Name="SettingsNavButton"
                    Style="{StaticResource TopBarCyanCircleButtonStyle}"
                    ToolTip="Settings"
                    Click="SettingsNavButton_OnClick">
              <Viewbox x:Name="SettingsNavIconHost" Width="16" Height="16" />
            </Button>
          </StackPanel>
          <Button Style="{StaticResource TopBarCloseCircleButtonStyle}"
                  Click="Close_OnClick"
                  ToolTip="Close">
            <Viewbox Width="11" Height="11">
              <Path Data="M3.72 3.72a.75.75 0 0 1 1.06 0L8 6.94l3.22-3.22a.75.75 0 1 1 1.06 1.06L9.06 8l3.22 3.22a.75.75 0 1 1-1.06 1.06L8 9.06l-3.22 3.22a.75.75 0 0 1-1.06-1.06L6.94 8 3.72 4.78a.75.75 0 0 1 0-1.06z"
                    Fill="#111111"
                    Stretch="Uniform" />
            </Viewbox>
          </Button>
        </StackPanel>
      </Grid>

      <!-- Main content -->
      <Grid x:Name="ContentHost"
            Margin="0,8,0,0"
            Background="Transparent">
        <Grid.RowDefinitions>
          <RowDefinition x:Name="CaptionRowDefinition" Height="0" />
          <RowDefinition x:Name="ContentMiddleRowDefinition" Height="*" />
          <RowDefinition x:Name="WizardFooterRowDefinition" Height="0" />
        </Grid.RowDefinitions>

        <Border x:Name="GptWebViewOpacityHost"
                Grid.Row="1"
                Background="Transparent"
                Visibility="Collapsed">
          <!-- WebView2 is an HWND: tool buttons sit in the column beside it (not overlaid). -->
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <wv2:WebView2 x:Name="GptWebView"
                          Grid.Column="0"
                          Visibility="Visible" />
            <StackPanel x:Name="GptSideToolStack"
                        Grid.Column="1"
                        VerticalAlignment="Top"
                        Margin="4,6,0,0"
                        Visibility="Collapsed">
              <Button x:Name="GptCopyResultButton"
                      Style="{StaticResource TopBarCyanCircleButtonStyle}"
                      Background="#b2ebf2"
                      Width="28"
                      Height="28"
                      Margin="0,0,0,4"
                      shell:WindowChrome.IsHitTestVisibleInChrome="True"
                      ToolTip="Copy latest ChatGPT reply"
                      Click="GptCopyResultButton_OnClick">
                <Viewbox x:Name="GptCopyResultIconHost" Width="14" Height="14" />
              </Button>
              <Button x:Name="GptImageButton"
                      Style="{StaticResource TopBarCyanCircleButtonStyle}"
                      Background="#b2ebf2"
                      Width="28"
                      Height="28"
                      Margin="0,0,0,4"
                      shell:WindowChrome.IsHitTestVisibleInChrome="True"
                      ToolTip="Snip screen → add image to ChatGPT prompt (does not send)"
                      Click="GptImageButton_OnClick">
                <Viewbox x:Name="GptImageIconHost" Width="14" Height="14" />
              </Button>
              <Button x:Name="GptTextButton"
                      Style="{StaticResource TopBarCyanCircleButtonStyle}"
                      Background="#b2ebf2"
                      Width="28"
                      Height="28"
                      Margin="0,0,0,4"
                      shell:WindowChrome.IsHitTestVisibleInChrome="True"
                      ToolTip="Snip screen → OCR text into ChatGPT prompt (does not send)"
                      Click="GptTextButton_OnClick">
                <Viewbox x:Name="GptTextIconHost" Width="14" Height="14" />
              </Button>
              <Button x:Name="GptFolderButton"
                      Style="{StaticResource TopBarCyanCircleButtonStyle}"
                      Background="#b2ebf2"
                      Width="28"
                      Height="28"
                      shell:WindowChrome.IsHitTestVisibleInChrome="True"
                      ToolTip="Pick folder → upload combined snapshot .txt to ChatGPT (like image attach; does not send). Shift+click: open transcripts folder."
                      Click="GptFolderButton_OnClick">
                <Viewbox x:Name="GptFolderIconHost" Width="14" Height="14" />
              </Button>
            </StackPanel>
          </Grid>
        </Border>

        <!-- Step 1: Resume + JD (no WebView) -->
        <Grid x:Name="Step1Panel"
              Grid.Row="0"
              Grid.RowSpan="3"
              Background="Transparent"
              Visibility="Visible"
              PreviewMouseLeftButtonDown="Step1Panel_PreviewMouseLeftButtonDown">
          <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <DockPanel Grid.Column="0" Margin="0,0,8,0" LastChildFill="True">
              <TextBlock DockPanel.Dock="Top"
                         Margin="0,0,0,8"
                         FontSize="15"
                         FontWeight="SemiBold"
                         Foreground="#0F172A"
                         Text="Resume" />
              <TextBox x:Name="ResumeTextBox"
                       AcceptsReturn="True"
                       AcceptsTab="True"
                       VerticalScrollBarVisibility="Auto"
                       HorizontalScrollBarVisibility="Disabled"
                       TextWrapping="Wrap"
                       VerticalContentAlignment="Top"
                       MinHeight="220"
                       FontSize="14"
                       Foreground="#1E293B"
                       BorderBrush="#CBD5E1"
                       BorderThickness="1"
                       Background="Transparent"
                       CaretBrush="#1E293B"
                       SpellCheck.IsEnabled="False"
                       IsUndoEnabled="True"
                       UndoLimit="100" />
            </DockPanel>
            <DockPanel Grid.Column="1" Margin="8,0,0,0" LastChildFill="True">
              <TextBlock DockPanel.Dock="Top"
                         Margin="0,0,0,8"
                         FontSize="15"
                         FontWeight="SemiBold"
                         Foreground="#0F172A"
                         Text="Job Description" />
              <TextBox x:Name="JdTextBox"
                       AcceptsReturn="True"
                       AcceptsTab="True"
                       VerticalScrollBarVisibility="Auto"
                       HorizontalScrollBarVisibility="Disabled"
                       TextWrapping="Wrap"
                       VerticalContentAlignment="Top"
                       MinHeight="220"
                       FontSize="14"
                       Foreground="#1E293B"
                       BorderBrush="#CBD5E1"
                       BorderThickness="1"
                       Background="Transparent"
                       CaretBrush="#1E293B"
                       SpellCheck.IsEnabled="False"
                       IsUndoEnabled="True"
                       UndoLimit="100" />
            </DockPanel>
          </Grid>
          <Button Grid.Row="1"
                  Style="{StaticResource WizardPrimaryButtonStyle}"
                  HorizontalAlignment="Center"
                  Width="140"
                  shell:WindowChrome.IsHitTestVisibleInChrome="True"
                  Click="Step1Continue_OnClick"
                  Content="Continue" />
        </Grid>

        <!-- Steps 2–5: title row, WebView middle, footer buttons (no bordered chrome) -->
        <Grid x:Name="WizardHeaderPanel"
              Grid.Row="0"
              Margin="0,0,0,6"
              Visibility="Collapsed"
              shell:WindowChrome.IsHitTestVisibleInChrome="True">
          <TextBlock x:Name="WizardTitleText"
                     FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="#0F172A"
                     TextAlignment="Center"
                     TextWrapping="Wrap" />
        </Grid>

        <Grid x:Name="WizardFooterPanel"
              Grid.Row="2"
              Margin="0,6,0,0"
              Visibility="Collapsed"
              shell:WindowChrome.IsHitTestVisibleInChrome="True">
          <StackPanel x:Name="WizardButtonRow"
                      HorizontalAlignment="Center"
                      Orientation="Horizontal">
            <Button x:Name="WizardSkipButton"
                    Style="{StaticResource WizardSkipButtonStyle}"
                    Width="140"
                    Margin="0,0,10,0"
                    Click="WizardSkip_OnClick"
                    Content="Skip"
                    Visibility="Collapsed" />
            <Button x:Name="WizardPrimaryButton"
                    Style="{StaticResource WizardPrimaryButtonStyle}"
                    Width="140"
                    Click="WizardPrimary_OnClick"
                    Content="Continue"
                    IsEnabled="False" />
          </StackPanel>
        </Grid>

        <!-- Main: captions 30% -->
        <Border x:Name="CaptionPanel"
                Grid.Row="0"
                Margin="0,0,0,4"
                Background="#ECECF0"
                BorderBrush="#E2E8F0"
                BorderThickness="0,0,0,1"
                CornerRadius="8"
                Visibility="Collapsed"
                Padding="10,8">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock x:Name="CaptionStatusText"
                       FontSize="11"
                       Foreground="#64748B"
                       TextWrapping="Wrap"
                       Margin="0,0,0,6"
                       Text="End = send · Delete = skip · Double-click bubble to edit" />
            <ui:CaptionFeedPanel x:Name="CaptionFeed"
                                 Grid.Row="1" />
          </Grid>
        </Border>

        <!-- Full-area settings (main interview): left nav + right editor -->
        <local:SettingsPanel x:Name="InterviewSettingsPanel"
                             Grid.Row="0"
                             Grid.RowSpan="3"
                             Visibility="Collapsed" />
      </Grid>
    </DockPanel>
      <ui:ToastOverlay x:Name="AppToastHost"
                       Panel.ZIndex="2000"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch" />
    </Grid>
  </Border>
</Window>
