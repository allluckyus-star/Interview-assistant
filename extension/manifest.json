{
  "manifest_version": 3,
  "name": "Interview Assistant Bridge",
  "version": "1.0.0",
  "description": "Pulls prompt from local bridge and inserts it into GPT site.",
  "permissions": ["storage", "identity", "identity.email", "tabs", "scripting", "alarms"],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "ws://127.0.0.1:8766/*",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Interview Assistant"
  },
  "content_scripts": [
    {
      "matches": ["https://chat.openai.com/*", "https://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
