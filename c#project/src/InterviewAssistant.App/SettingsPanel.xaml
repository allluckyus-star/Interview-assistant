<UserControl x:Class="InterviewAssistant.App.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed">
  <UserControl.Resources>
    <LinearGradientBrush x:Key="SettingsCanvasBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#F5F3FF" Offset="0" />
      <GradientStop Color="#F8FAFC" Offset="0.55" />
      <GradientStop Color="#ECFEFF" Offset="1" />
    </LinearGradientBrush>
  </UserControl.Resources>

  <Grid Background="{StaticResource SettingsCanvasBrush}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" MinWidth="200" MaxWidth="320" />
      <ColumnDefinition Width="12" />
      <ColumnDefinition Width="1.65*" MinWidth="280" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0"
            Background="#FFFFFF"
            CornerRadius="16"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            Padding="18,16">
      <Border.Effect>
        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.06" Color="#0F172A" />
      </Border.Effect>
      <DockPanel LastChildFill="True">
        <Button DockPanel.Dock="Top"
                Style="{StaticResource RoundedPillButtonStyle}"
                HorizontalAlignment="Left"
                Margin="0,0,0,12"
                Padding="10,8"
                Background="#b2ebf2"
                Foreground="#212121"
                Click="SettingsBackButton_OnClick">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="←" FontSize="14" Margin="0,0,6,0" />
            <TextBlock Text="Back to interview" />
          </StackPanel>
        </Button>

        <TextBlock DockPanel.Dock="Top"
                   Text="Prompt templates"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="#0F172A"
                   Margin="0,0,0,12" />

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel>
            <Button x:Name="NavResumeSummary" Tag="resume_summary" Style="{StaticResource SettingsNavButtonStyle}" Click="ModeNav_OnClick" Content="Resume summary" />
            <Button x:Name="NavJdSummary" Tag="jd_summary" Style="{StaticResource SettingsNavButtonStyle}" Click="ModeNav_OnClick" Content="JD summary" />
            <Button x:Name="NavInitialInterview" Tag="initial_interview" Style="{StaticResource SettingsNavButtonStyle}" Click="ModeNav_OnClick" Content="Initial interview" />
            <Button x:Name="NavRead" Tag="read" Style="{StaticResource SettingsNavButtonStyle}" Click="ModeNav_OnClick" Content="Read" />
            <Button x:Name="NavType" Tag="type" Style="{StaticResource SettingsNavButtonStyle}" Click="ModeNav_OnClick" Content="Type" />
            <Button x:Name="NavError" Tag="error" Style="{StaticResource SettingsNavButtonStyle}" Click="ModeNav_OnClick" Content="Error / debug" />
            <Button x:Name="NavBehavioral" Tag="behavioral" Style="{StaticResource SettingsNavButtonStyle}" Click="ModeNav_OnClick" Content="Behavioral" />
            <Button x:Name="NavClosing" Tag="closing" Style="{StaticResource SettingsNavButtonStyle}" Click="ModeNav_OnClick" Content="Closing questions" />
          </StackPanel>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <Border Grid.Column="2"
            Background="#FFFFFF"
            CornerRadius="16"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            Padding="20,18">
      <Border.Effect>
        <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.08" Color="#0F172A" />
      </Border.Effect>
      <DockPanel LastChildFill="True">
        <TextBlock x:Name="EditorModeTitle"
                   DockPanel.Dock="Top"
                   Text="Resume summary"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#0F172A"
                   Margin="0,0,0,12" />

        <Button DockPanel.Dock="Bottom"
                Margin="0,12,0,0"
                HorizontalAlignment="Right"
                Style="{StaticResource SettingsSaveButtonStyle}"
                Content="Save"
                Click="SettingsSavePromptButton_OnClick" />

        <Border Background="#F8FAFC"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Padding="2">
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <TextBox x:Name="SettingsEditor"
                     Style="{StaticResource SettingsEditorTextStyle}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Disabled"
                     Background="Transparent"
                     BorderThickness="0"
                     MinHeight="320"
                     Padding="14,12" />
          </ScrollViewer>
        </Border>
      </DockPanel>
    </Border>
  </Grid>
</UserControl>
