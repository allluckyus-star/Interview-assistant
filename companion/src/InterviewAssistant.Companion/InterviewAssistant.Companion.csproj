    <Compile Include="..\..\..\c#project\src\InterviewAssistant.App\Services\InterviewHistory.cs" Link="Linked\InterviewHistory.cs" />
    <Compile Include="..\..\..\c#project\src\InterviewAssistant.App\Services\InterviewHotkeyService.cs" Link="Linked\InterviewHotkeyService.cs" />
    <Compile Include="..\..\..\c#project\src\InterviewAssistant.App\ResumeJdHistoryStore.cs" Link="Linked\ResumeJdHistoryStore.cs" />
