    <Compile Include="..\..\..\c#project\src\InterviewAssistant.App\ResumeJdStore.cs" Link="Linked\ResumeJdStore.cs" />
    <Compile Include="..\..\..\c#project\src\InterviewAssistant.App\PromptTemplateResolver.cs" Link="Linked\PromptTemplateResolver.cs" />
    <Compile Include="..\..\..\c#project\src\InterviewAssistant.App\Services\StartupDiagnostics.cs" Link="Linked\StartupDiagnostics.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\..\c#project\src\InterviewAssistant.App\Assets\**\*">
      <Link>Assets\%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
